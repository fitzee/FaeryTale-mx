DEFINITION MODULE Carrier;

(* Carrier/riding system — raft, turtle, swan.
   Original: actor slot 1 = raft, slot 3 = carrier (turtle/swan).
   Player mounts carriers by proximity, dismounts by stopping. *)

CONST
  RideNone  = 0;
  RideRaft  = 1;
  RideTurtle = 5;
  RideSwan  = 11;

VAR
  riding: INTEGER;        (* 0=none, 1=raft, 5=turtle, 11=swan *)
  activeCarrier: INTEGER; (* carrier type loaded, 0=none *)
  turtleEggs: BOOLEAN;     (* TRUE when in turtle egg extent, snakes spawned *)
  turtleEggsDone: BOOLEAN; (* TRUE after eggs saved — prevents re-trigger *)

PROCEDURE InitCarriers;
PROCEDURE UpdateCarriers;
PROCEDURE SpawnTurtle;    (* called from USE→Shell or aftermath *)
PROCEDURE TalkToCarrier(VAR speech: ARRAY OF CHAR): BOOLEAN;
PROCEDURE SpawnDragon;    (* called when entering dragon cave extent *)
PROCEDURE UpdateDragon;   (* dragon AI — sets dragonFire flag *)

VAR
  dragonFire: BOOLEAN;    (* TRUE = dragon wants to fire this frame *)
  swanDismount: BOOLEAN;  (* TRUE = player wants to dismount swan *)
  dismountResult: INTEGER; (* 0=ok, 1=too fast, 2=too hot, 3=bad terrain *)
  swanCooldown: INTEGER;   (* frames before remount/attack allowed *)

END Carrier.
